# Telegram API Configurations (Get these from https://my.telegram.org)
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=your_api_hash_here

# Telegram Bot Token (Get this from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ

# Destination Telegram Channel ID or Username (e.g. -1001234567890 or @my_deal_channel)
MY_TELEGRAM_CHANNEL=-100XXXXXXXXXX

# Target Telegram Channels to Listen To (Comma-separated channel IDs or usernames)
# Example: -1001111111111, -1002222222222, @some_deal_channel
TARGET_CHANNELS=-100YYYYYYYYYY,-100ZZZZZZZZZZ

# Whitelisted Telegram Channels (Skip link conversion. Comma-separated IDs or usernames)
WHITELIST_CHANNELS=

# Discord Webhook URL for posting Rich Embeds
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# EarnKaro Affiliate Partner ID (For transforming original URLs)
EARNKARO_PARTNER_ID=YOUR_PARTNER_ID

# Smart Posting Delay between consecutive posts to prevent spam (in seconds. E.g. 900 = 15 minutes. Set to 0 to disable)
DELAY_INTERVAL=900
